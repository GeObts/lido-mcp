# Lido MCP Server Environment Configuration
# NEVER commit real private keys to git. Copy this file to .env and fill in your values.

# Required: Private key for signing transactions (keep this secret!)
# The server checks for this key in order:
#   1. AOX_BANKER_PRIVATE_KEY environment variable (e.g. set in MCP client config)
#   2. This .env file in the project root
#   3. ~/.openclaw/.env (legacy AOX agent path)
AOX_BANKER_PRIVATE_KEY=your_private_key_here_never_commit_real_keys

# Optional: Custom RPC endpoints (defaults shown below)
ETH_RPC=https://eth.llamarpc.com
BASE_RPC=https://mainnet.base.org
